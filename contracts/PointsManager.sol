pragma solidity ^0.8.20;
contract PointsManager { address public owner; uint256 public currentSeason=1; struct Stats{uint256 totalPoints;uint256 seasonPoints;uint256 votes;uint256 battlesCreated;uint256 wins;uint256 swaps;uint256 liquidityActions;uint256 referrals;uint256 streakDays;bool verified;bool xConnected;uint256 badgesBitmap;} mapping(address=>Stats) public stats; mapping(uint256=>mapping(address=>uint256)) public seasonHistory; modifier onlyOwner(){require(msg.sender==owner,'Not owner');_;} constructor(){owner=msg.sender;} function addPoints(address user,uint256 amount) public onlyOwner {stats[user].totalPoints+=amount; stats[user].seasonPoints+=amount;} function recordVote(address user) external onlyOwner {stats[user].votes+=1; addPoints(user,1);} function recordBattle(address user) external onlyOwner {stats[user].battlesCreated+=1; addPoints(user,5);} function recordWin(address user) external onlyOwner {stats[user].wins+=1; addPoints(user,3);} function recordSwap(address user) external onlyOwner {stats[user].swaps+=1; addPoints(user,2);} function recordLiquidity(address user) external onlyOwner {stats[user].liquidityActions+=1; addPoints(user,4);} function setVerified(address user,bool value) external onlyOwner {stats[user].verified=value;} function setXConnected(address user,bool value) external onlyOwner {stats[user].xConnected=value;} function setBadgeBitmap(address user,uint256 bitmap) external onlyOwner {stats[user].badgesBitmap=bitmap;} function closeSeason(address[] calldata users) external onlyOwner {for(uint i=0;i<users.length;i++){seasonHistory[currentSeason][users[i]]=stats[users[i]].seasonPoints;stats[users[i]].seasonPoints=0;} currentSeason+=1;}}